rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper functions ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidFileSize() {
      // Max 10 MB per file
      return request.resource.size <= 10 * 1024 * 1024;
    }

    function isValidUpload() {
      return isImageFile() && isValidFileSize();
    }

    function isAllowedChatAttachmentType() {
      return request.resource.contentType.matches('image/.*') ||
        request.resource.contentType.matches('video/.*') ||
        request.resource.contentType.matches('application/pdf');
    }

    function chatDocument(chatId) {
      return firestore.get(/databases/(default)/documents/chats/$(chatId));
    }

    function chatExists(chatId) {
      return firestore.exists(/databases/(default)/documents/chats/$(chatId));
    }

    function isChatParticipant(chatId) {
      return isSignedIn() &&
        chatExists(chatId) &&
        request.auth.uid in chatDocument(chatId).data.participants;
    }

    // ─── Profile photos ───────────────────────────────────────────────
    match /profile_photos/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ─── Profile banners ──────────────────────────────────────────────
    match /profile_banners/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ─── Product images ───────────────────────────────────────────────
    match /products/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ─── Service images ───────────────────────────────────────────────
    match /services/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ─── Chat attachments ─────────────────────────────────────────────
    match /chat_attachments/{chatId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId) &&
        isValidFileSize() &&
        isAllowedChatAttachmentType();
      allow delete: if isChatParticipant(chatId);
    }

    // ─── Portfolio images ─────────────────────────────────────────────
    match /portfolio/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ─── Company logos ────────────────────────────────────────────────
    match /company_logos/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isValidUpload();
      allow delete: if isOwner(userId);
    }

    // ─── ID verification documents (sensitive) ────────────────────────
    match /verification/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidFileSize();
      allow delete: if isOwner(userId);
    }

    // ─── Deny all other paths ─────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
