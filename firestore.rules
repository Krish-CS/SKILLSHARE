rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection - basic user info
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && request.resource.data.role != 'admin' || isAdmin();
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'email', 'createdAt', 'isActive', 'isSuspended']) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // Skilled users profiles collection
    match /skilled_users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      // Owner cannot self-verify or artificially boost ratings.
      // others can update rating/reviewCount (review flow), profileViews (analytics flow), or projectCount.
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['isVerified', 'verificationStatus', 'verifiedAt', 'rejectionReason',
                   'rating', 'reviewCount', 'profileViews', 'projectCount', 'companyEndorsementCount'])) ||
        (!isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'reviewCount', 'updatedAt', 'profileViews', 'projectCount', 'companyEndorsementCount']))
      );
      allow delete: if isOwner(userId) || isAdmin();

      match /profile_viewers/{viewerId} {
        allow read: if isAuthenticated() &&
          (isOwner(userId) || request.auth.uid == viewerId);
        allow create: if isAuthenticated() &&
          request.auth.uid == viewerId &&
          request.resource.data.viewerId == request.auth.uid &&
          userId != request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Customer profiles collection
    match /customer_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      // Owners cannot self-verify. Others can append projects safely.
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['isVerified', 'verificationStatus', 'verifiedAt', 'rating', 'reviewCount'])) ||
        (!isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['assignedProjects', 'updatedAt']))
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Company profiles collection
    match /company_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      // Owners cannot self-verify or self-rate. Others can rate or append projects safely.
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['isVerified', 'verificationStatus', 'verifiedAt', 'rating', 'reviewCount'])) ||
        (!isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['assignedProjects', 'updatedAt', 'rating', 'reviewCount']))
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Portfolio collection
    match /portfolio/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // Owner can update everything; others can only adjust engagement counters.
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'views'])
      );
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      match /likes/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.auth.uid == userId &&
          request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && request.auth.uid == userId;
        allow update: if false;
      }

      match /viewers/{viewerId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == viewerId ||
           request.auth.uid == get(/databases/$(database)/documents/portfolio/$(itemId)).data.userId);
        allow create: if isAuthenticated() &&
          request.auth.uid == viewerId &&
          request.resource.data.viewerId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Aadhaar registry collection
    match /aadhaar_registry/{aadhaarNumber} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (
          resource.data.userId == request.auth.uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'isAvailable', 'updatedAt']) &&
            request.resource.data.stock >= 0 &&
            request.resource.data.stock <= resource.data.stock
          )
        );
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // Custom skills suggestions
    match /custom_skills/{skillId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if false;
    }

    // Cart collection (per-user subcollection)
    match /carts/{userId}/items/{itemId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid ||
         resource.data.sellerId == request.auth.uid ||
         resource.data.deliveryPartnerId == request.auth.uid ||
         (resource.data.deliveryByPartner == true && (!("deliveryPartnerId" in resource.data) || resource.data.deliveryPartnerId == null || resource.data.deliveryPartnerId == '')));
      allow create: if isAuthenticated() &&
        request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.sellerId == request.auth.uid ||
         resource.data.buyerId == request.auth.uid ||
         resource.data.deliveryPartnerId == request.auth.uid ||
         (resource.data.deliveryByPartner == true && request.resource.data.deliveryPartnerId == request.auth.uid));
      allow delete: if false;
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.reviewerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.reviewerId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.reviewerId == request.auth.uid;
    }
    
    // Jobs collection
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        (request.resource.data.companyId == request.auth.uid ||
         request.resource.data.postedBy == request.auth.uid);
      allow update: if isAuthenticated() && (
        resource.data.companyId == request.auth.uid ||
        resource.data.postedBy == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['applicants', 'applicationStatus', 'updatedAt', 'applicationChatIds']) &&
          (!('applicationStatus' in request.resource.data.diff(resource.data).affectedKeys()) ||
             (request.resource.data.get('applicationStatus', {}).diff(resource.data.get('applicationStatus', {})).affectedKeys().hasOnly([request.auth.uid]) &&
              request.resource.data.get('applicationStatus', {})[request.auth.uid] == 'pending')
          ) &&
          (!('applicationChatIds' in request.resource.data.diff(resource.data).affectedKeys()) ||
             request.resource.data.get('applicationChatIds', {}).diff(resource.data.get('applicationChatIds', {})).affectedKeys().hasOnly([request.auth.uid])
          ) &&
          (!('applicants' in request.resource.data.diff(resource.data).affectedKeys()) ||
             request.auth.uid in request.resource.data.applicants
          )
        )
      );
      allow delete: if isAuthenticated() &&
        (resource.data.companyId == request.auth.uid ||
         resource.data.postedBy == request.auth.uid);
    }
    
    // Service requests collection
    match /requests/{requestId} {
      allow read: if isAuthenticated() && 
        (resource.data.requesterId == request.auth.uid ||
         resource.data.customerId == request.auth.uid || 
         resource.data.skilledUserId == request.auth.uid ||
         request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && 
        (
          (resource.data.requesterId == request.auth.uid ||
           resource.data.customerId == request.auth.uid ||
           (request.auth.uid in resource.data.participants && resource.data.skilledUserId != request.auth.uid))
          ||
          (resource.data.skilledUserId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'responseMessage', 'respondedAt', 'updatedAt', 'workChatId', 'rejectionReason']) &&
           (resource.data.status != 'completed' || request.resource.data.status == 'completed')
          )
        );
      allow delete: if isAuthenticated() &&
        (resource.data.requesterId == request.auth.uid ||
         resource.data.customerId == request.auth.uid);
    }
    
    // Chats collection
    match /chats/{chatId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participants &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants']);
      allow delete: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        // Sender can update own messages; participants can mark as read
        allow update: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid ||
          (
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt'])
          )
        );
        allow delete: if isAuthenticated() &&
          request.auth.uid == resource.data.senderId;
      }
    }
    
    // Appeals collection
    match /appeals/{appealId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Reports collection
    match /reports/{reportId} {
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow read: if isAuthenticated() &&
        (resource.data.reporterId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Admin-managed company/skilled member directory
    match /managed_members/{memberId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Blocked users
    match /blocked_users/{blockId} {
      allow create: if isAuthenticated() &&
        request.resource.data.blockerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;
      allow read: if isAuthenticated() &&
        (resource.data.blockerId == request.auth.uid ||
         resource.data.blockedUserId == request.auth.uid);
      allow delete: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;
    }

    // Support tickets
    match /support_tickets/{ticketId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow read, update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isAuthenticated() &&
        resource.data.toUserId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.toUserId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.toUserId == request.auth.uid;
    }

    // Delivery assignments
    match /delivery_assignments/{assignmentId} {
      allow read: if isAuthenticated() &&
        (resource.data.deliveryPartnerId == request.auth.uid ||
         resource.data.sellerId == request.auth.uid ||
         resource.data.buyerId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.deliveryPartnerId == request.auth.uid ||
         resource.data.sellerId == request.auth.uid);
      allow delete: if false;
    }
  }
}
